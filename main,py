import os
import telebot
from groq import Groq
from dotenv import load_dotenv

load_dotenv()

TELEGRAM_TOKEN = os.getenv("TELEGRAM_TOKEN")
GROQ_API_KEY = os.getenv("GROQ_API_KEY")

bot = telebot.TeleBot(TELEGRAM_TOKEN)
groq_client = Groq(api_key=GROQ_API_KEY)

# 대화 기록 저장 (메모리)
user_histories = {}
SYSTEM_PROMPT = "당신은 도움이 되고 친절한 AI 어시스턴트입니다. 한국어로 자연스럽고 정확하게 대답하세요."
MAX_TURNS = 8  # 최근 대화 턴 수 제한 (메모리 절약)

@bot.message_handler(commands=['start', 'help'])
def send_welcome(message):
    chat_id = message.chat.id
    user_histories[chat_id] = [{"role": "system", "content": SYSTEM_PROMPT}]
    bot.reply_to(message, 
        "🦙 **Llama 3.3 70B Versatile** 챗봇입니다!\n\n"
        "자유롭게 질문하세요.\n"
        "• `/reset` - 대화 초기화\n"
        "• `/help` - 도움말")

@bot.message_handler(commands=['reset'])
def reset_chat(message):
    chat_id = message.chat.id
    user_histories[chat_id] = [{"role": "system", "content": SYSTEM_PROMPT}]
    bot.reply_to(message, "✅ 대화 기록이 초기화되었습니다!")

@bot.message_handler(func=lambda message: True)
def handle_message(message):
    chat_id = message.chat.id
    user_text = message.text

    # 히스토리 없으면 초기화
    if chat_id not in user_histories:
        user_histories[chat_id] = [{"role": "system", "content": SYSTEM_PROMPT}]

    # 사용자 메시지 추가
    user_histories[chat_id].append({"role": "user", "content": user_text})

    # 히스토리 길이 제한 (system + 최근 대화만 유지)
    if len(user_histories[chat_id]) > MAX_TURNS * 2 + 1:
        user_histories[chat_id] = [user_histories[chat_id][0]] + user_histories[chat_id][-(MAX_TURNS*2):]

    try:
        # 타이핑 표시
        bot.send_chat_action(chat_id, 'typing')

        # Groq API 호출
        response = groq_client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=user_histories[chat_id],
            temperature=0.7,
            max_tokens=2048,
            top_p=0.9,
        )

        assistant_reply = response.choices[0].message.content

        # 어시스턴트 응답 저장
        user_histories[chat_id].append({"role": "assistant", "content": assistant_reply})

        # 텔레그램 메시지 길이 제한 처리 (4096자)
        if len(assistant_reply) > 4000:
            for i in range(0, len(assistant_reply), 4000):
                bot.send_message(chat_id, assistant_reply[i:i+4000])
        else:
            bot.send_message(chat_id, assistant_reply)

    except Exception as e:
        bot.send_message(chat_id, f"❌ 오류가 발생했습니다.\n\n{str(e)}\n\n잠시 후 다시 시도해주세요.")
        # 오류 발생 시 마지막 user 메시지 제거
        if user_histories[chat_id][-1]["role"] == "user":
            user_histories[chat_id].pop()

print("🤖 봇이 실행 중입니다...")
bot.infinity_polling()
